+_INLINE_TOKEN_RE = re.compile(
+    r"(\*\*[^*]+\*\*)"               # 1. **bold**
+    r"|(\*[^*]+\*)"                  # 2. *italic*
+    r"|(<u>[^<]+</u>)"                # 3. <u>...</u>
+    r"|(<mark>[^<]+</mark>)"          # 4. <mark>...</mark>
+    r"|(<span style=\"color:[^\"]+\">[^<]+</span>)"  # 5. color span
+    r"|(\[[^\]]+\]\([^\)]+\))"       # 6. [text](href)
+)
+
+
+def render_inline(text: str) -> str:
+    """Escape body text but preserve a fixed set of inline marks as HTML.
+
+    Supported (matches the editor's mark set):
+      **bold**, *italic*, <u>underline</u>, <mark>highlight</mark>,
+      <span style="color:#xxx">colored</span>, [link](href)
+    """
+    out: list[str] = []
+    last = 0
+    for m in _INLINE_TOKEN_RE.finditer(text):
+        if m.start() > last:
+            out.append(_html_escape(text[last:m.start()]))
+        token = m.group(0)
+        if m.group(1):
+            inner = _html_escape(token[2:-2])
+            out.append(f"<b>{inner}</b>")
+        elif m.group(2):
+            inner = _html_escape(token[1:-1])
+            out.append(f"<i>{inner}</i>")
+        elif m.group(3):
+            inner = _html_escape(token[3:-4])
+            out.append(f"<u>{inner}</u>")
+        elif m.group(4):
+            inner = _html_escape(token[6:-7])
+            out.append(f'<span style="background-color:#fff593;">{inner}</span>')
+        elif m.group(5):
+            # color spans are already trusted HTML from the editor — keep as-is
+            out.append(token)
+        elif m.group(6):
+            # [text](href)
+            close = token.index("](")
+            label = _html_escape(token[1:close])
+            href = _html_escape(token[close + 2:-1])
+            out.append(f'<a href="{href}" target="_blank">{label}</a>')
+        last = m.end()
+    if last < len(text):
+        out.append(_html_escape(text[last:]))
+    return "".join(out)
+
+
